# ── 大模型(DashScope / OpenAI 兼容) ──
DASHSCOPE_API_KEY=sk-replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus
REQUEST_TIMEOUT=180
MODEL_MAX_RETRIES=1
# 开发时设 1 可用确定性 mock 回复,免真实模型/网络
MOCK_LLM=0

# ── 数据采集 ──
NEWS_LIMIT=3
PROMPT_VERSION=v5

# ── 调度器 ──
SCHEDULER_ENABLED=1
SCHEDULER_INTERVAL_SECONDS=1800
SCHEDULER_DAILY_ENABLED=1

# ── 多用户 / 鉴权 / 计费 ──
COOKIE_SECURE=false                 # 生产 HTTPS 置 true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me            # 首次启动 seed 管理员;务必改
FREE_DAILY_CENTS=300                # 免费用户每日 LLM 额度(分),300=3元
SESSION_TTL_HOURS=720
ENABLE_REGISTRATION=1

# ── 旧版管理通道(可留空) / 测试推送 ──
ADMIN_TOKEN=
ALLOW_TEST_NOTIFY=0
